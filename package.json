{
  "name": "vite-react-ssg-pro",
  "private": true,
  "version": "1.7.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm lint && pnpm core:build && pnpm og-screenshots",
    "core:build": "cross-env NODE_ENV=production vite build && pnpm prerender && pnpm compress",
    "preview": "vite preview",
    "lint": "tsx scripts/lint.ts",
    "unused": "knip --production --dependencies --files --exports --include-entry-exports && depcheck",
    "test": "pnpm lint && pnpm core:build && vite preview",
    "upload": "pnpm build && wrangler pages deploy ./dist",
    "prerender": "tsx --tsconfig tsconfig.app.json scripts/prerender.ts",
    "compress": "tsx --tsconfig tsconfig.app.json scripts/compress.ts",
    "og-screenshots": "python scripts/generate_og_screenshots.py --port 5173 --seo src/seo.json --cleanup",
    "analyze": "cross-env ANALYZE=true pnpm core:build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^6.0.1",
    "beasties": "^0.4.1",
    "cross-env": "^10.1.0",
    "depcheck": "^1.4.7",
    "eslint": "^10.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "framer-motion": "^12.38.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "knip": "^6.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-router": "^7.13.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.2",
    "terser": "^5.46.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vite-plugin-inspect": "12.0.0-beta.1",
    "vite-plugin-qrcode": "^0.4.1",
    "wrangler": "^4.79.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
